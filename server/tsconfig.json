{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node",
        "types": [
            "node"
        ]
    },
    "include": [
        "src/**/*",
        "prisma/**/*.ts",
        "prisma.config.ts"
    ]
}